{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rex Assistant Profile",
  "description": "Profile configuration for Rex AI Assistant",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "profile_version": {
      "type": "integer",
      "const": 1,
      "description": "Profile schema version"
    },
    "name": {
      "type": "string",
      "description": "Profile name"
    },
    "description": {
      "type": "string",
      "description": "Human readable profile description"
    },
    "capabilities": {
      "type": "array",
      "description": "Enabled capabilities for this profile",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "overrides": {
      "type": "object",
      "description": "Overrides applied on top of rex_config.json",
      "additionalProperties": true,
      "default": {}
    }
  },
  "required": ["profile_version", "name", "description", "capabilities", "overrides"]
}
