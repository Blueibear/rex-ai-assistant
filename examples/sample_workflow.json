{
  "workflow_id": "wf_sample_001",
  "title": "Sample Time Check Workflow",
  "steps": [
    {
      "step_id": "get_time",
      "description": "Get current local time in Dallas",
      "tool_call": {
        "tool": "time_now",
        "args": {
          "location": "Dallas, TX"
        }
      }
    },
    {
