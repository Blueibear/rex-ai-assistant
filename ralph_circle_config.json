{
  "primary_agent_name": "claude-code",
  "primary_agent_command_template": "powershell -NoProfile -ExecutionPolicy Bypass -File \"scripts\\run_primary_agent.ps1\" -RepoRoot \"{repo_root}\" -PromptFile \"{prompt_file}\" -LogFile \"{log_file}\" -Iteration {iteration}",
  "verifier_enabled": true,
  "verifier_name": "claude-code-verifier",
  "verifier_command_template": "powershell -NoProfile -ExecutionPolicy Bypass -File \"scripts\\run_verifier_agent.ps1\" -RepoRoot \"{repo_root}\" -PromptFile \"{prompt_file}\" -LogFile \"{log_file}\" -Iteration {iteration}",
  "repo_root": ".",
  "task_board_path": "RALPH_TASK_BOARD.md",
  "loop_prompt_path": "RALPH_CIRCLE_PROMPT.md",
  "backup_dir": ".ralph_backups",
  "log_dir": ".ralph_logs",
  "state_file": ".ralph_state.json",
  "max_iterations": 200,
  "stall_limit": 3,
  "require_git_repo": true,
  "backup_on_start": true,
  "auto_git_tag_on_start": true,
  "start_tag_name": "ralph-start",
  "stop_on_blocked_tasks": true,
  "stop_on_primary_nonzero_exit": true,
  "stop_on_verifier_nonzero_exit": true,
  "stop_if_no_task_board_progress": true
}
