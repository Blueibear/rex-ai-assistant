{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.d.ts",
    "src/preload/index.d.ts",
    "src/types/**/*",
    "src/components/**/*",
    "src/layouts/**/*",
    "src/pages/**/*",
    "src/store/**/*",
    "src/hooks/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/renderer/src/*"
      ]
    }
  }
}
