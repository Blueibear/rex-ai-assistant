# ================================
# Rex AI Assistant - Secrets Only
# ================================
# This file contains only API keys and secrets.
# Runtime configuration is now in config/rex_config.json
#
# Copy this file to .env and fill in your API keys
#
# IMPORTANT:
# - Non-secret settings (wake word, models, audio, etc.) are now in config/rex_config.json
# - Edit config/rex_config.json for runtime settings
# - Edit .env only for API keys and secrets

# ============================================================================
# LLM Provider API Keys
# ============================================================================

# OpenAI API key (for GPT models)
OPENAI_API_KEY=

# Ollama API key (only if using cloud-hosted Ollama)
OLLAMA_API_KEY=

# ============================================================================
# Web Search API Keys
# ============================================================================

# Brave Search API key
BRAVE_API_KEY=

# SerpAPI key for Google search
SERPAPI_KEY=

# Google Custom Search Engine API key
GOOGLE_API_KEY=

# Google Custom Search Engine ID
GOOGLE_CSE_ID=

# ============================================================================
# Search Provider Endpoints (URLs)
# ============================================================================

# SerpAPI endpoint URL
SERPAPI_URL=https://serpapi.com/search

# Brave Search API endpoint
BRAVE_URL=https://api.search.brave.com/res/v1/web/search

# Google Custom Search API endpoint
GOOGLE_URL=https://www.googleapis.com/customsearch/v1

# Browserless API endpoint
BROWSERLESS_URL=https://chrome.browserless.io

# ============================================================================
# Browserless (Web Scraping)
# ============================================================================

# Browserless API key
BROWSERLESS_API_KEY=

# ============================================================================
# Rex Speak API (External TTS Service)
# ============================================================================

# Rex Speak API key
REX_SPEAK_API_KEY=

# Rex Speak storage URI (Redis or other backend)
REX_SPEAK_STORAGE_URI=

# ============================================================================
# Home Assistant Integration
# ============================================================================

# Home Assistant long-lived access token
HA_TOKEN=

# Home Assistant webhook secret
HA_SECRET=

# Legacy Home Assistant secret name
HASS_SECRET=

# ============================================================================
# Rate Limiting Storage
# ============================================================================

# Flask limiter storage URI (Redis recommended)
# Example: redis://localhost:6379
FLASK_LIMITER_STORAGE_URI=

# ============================================================================
# Internal Authentication
# ============================================================================

# Rex proxy authentication token
REX_PROXY_TOKEN=

# ============================================================================
# Migration Notes
# ============================================================================
# If you have an old .env file with runtime settings (like REX_WAKEWORD,
# REX_LLM_PROVIDER, REX_SAMPLE_RATE, etc.), those are now in config/rex_config.json.
#
# When you first run the GUI or CLI, it will automatically migrate these settings
# to config/rex_config.json. After migration, you can remove them from .env.
#
# See config/rex_config.example.json for the new configuration format.
