# =============================================================================
# Rex AI Assistant — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in the values that apply to your deployment.
#
#   cp .env.example .env
#
# SECRETS (API keys, tokens, passwords) belong here.
# Runtime settings (models, audio, wake word, etc.) belong in
#   config/rex_config.json — do NOT put runtime settings in .env.
#
# Convention:
#   REQUIRED  — the application cannot start / function without this value
#   Optional  — defaults shown; omit the variable to use the default


# =============================================================================
# LLM Provider API Keys
# =============================================================================

# OpenAI API key — REQUIRED when using the OpenAI provider
OPENAI_API_KEY=

# Anthropic API key — REQUIRED when using the Anthropic/Claude provider
ANTHROPIC_API_KEY=

# Ollama API key — only required when using a cloud-hosted Ollama endpoint
#                   that enforces authentication; leave blank for local Ollama
OLLAMA_API_KEY=


# =============================================================================
# LLM Provider Base URLs (Optional overrides)
# =============================================================================

# Custom base URL for the OpenAI-compatible API
# Default: https://api.openai.com/v1  (or the SDK default)
# Acceptable: any http/https URL, e.g. http://localhost:1234/v1
OPENAI_BASE_URL=

# Ollama API base URL
# Default: http://localhost:11434
OLLAMA_BASE_URL=


# =============================================================================
# Home Assistant Integration
# =============================================================================

# Home Assistant base URL — REQUIRED when HA integration is enabled
# Example: http://homeassistant.local:8123
HA_BASE_URL=

# Home Assistant long-lived access token — REQUIRED when HA integration is enabled
HA_TOKEN=

# Home Assistant webhook secret (used for incoming webhook authentication)
HA_SECRET=


# =============================================================================
# Web Search API Keys
# =============================================================================

# Brave Search API key (optional; enables Brave as a search provider)
BRAVE_API_KEY=

# SerpAPI key — enables Google search via SerpAPI
SERPAPI_KEY=

# Google Custom Search Engine API key
GOOGLE_API_KEY=

# Google Custom Search Engine ID
GOOGLE_CSE_ID=


# =============================================================================
# Search Provider Endpoint URLs (Optional overrides)
# =============================================================================

# SerpAPI endpoint URL
# Default: https://serpapi.com/search
SERPAPI_URL=https://serpapi.com/search

# Brave Search API endpoint
# Default: https://api.search.brave.com/res/v1/web/search
BRAVE_URL=https://api.search.brave.com/res/v1/web/search

# Google Custom Search API endpoint
# Default: https://www.googleapis.com/customsearch/v1
GOOGLE_URL=https://www.googleapis.com/customsearch/v1


# =============================================================================
# Browserless (Web Scraping — Optional)
# =============================================================================

# Browserless API endpoint
# Default: https://chrome.browserless.io
BROWSERLESS_URL=https://chrome.browserless.io

# Browserless API key (required if using Browserless)
BROWSERLESS_API_KEY=


# =============================================================================
# Rex Speak API (TTS Service)
# =============================================================================

# Authentication key required by the Rex Speak API server
REX_SPEAK_API_KEY=

# Port the Rex Speak API server listens on
# Default: 5005  — Acceptable: any valid port integer
REX_SPEAK_PORT=

# Coqui XTTS model identifier
# Default: tts_models/multilingual/multi-dataset/xtts_v2
REX_TTS_MODEL=

# Maximum text length accepted per TTS request (characters)
# Default: 800
REX_SPEAK_MAX_CHARS=

# Rate limit: requests allowed per window
# Default: 30
REX_SPEAK_RATE_LIMIT=

# Rate limit window in seconds
# Default: 60
REX_SPEAK_RATE_WINDOW=

# Storage URI for Flask-Limiter on the Speak API (Redis recommended)
# Example: redis://localhost:6379
# Default: memory://  (in-process, not suitable for multi-worker deployments)
REX_SPEAK_STORAGE_URI=


# =============================================================================
# Flask Proxy / Main API Server
# =============================================================================

# Authentication token required to call the Rex proxy API
REX_PROXY_TOKEN=

# Allow unauthenticated requests from localhost (1=yes, 0=no)
# Default: 0
REX_PROXY_ALLOW_LOCAL=0

# Comma-separated list of trusted reverse-proxy IPs (used to read X-Forwarded-For)
# Default: 127.0.0.1,::1
REX_TRUSTED_PROXIES=127.0.0.1,::1

# Flask-Limiter storage URI for the main API server (Redis recommended)
# Example: redis://localhost:6379
# Default: memory://
FLASK_LIMITER_STORAGE_URI=

# Per-IP rate limit applied to public endpoints (Flask-Limiter string)
# Default: 60 per minute
API_RATE_LIMIT=


# =============================================================================
# Database Connection Pool
# =============================================================================

# Minimum SQLite connections kept open
# Default: 1
DB_POOL_MIN_SIZE=

# Maximum concurrent SQLite connections
# Default: 5
DB_POOL_MAX_SIZE=

# Seconds to wait for a free connection before raising ConnectionPoolError
# Default: 5.0
DB_POOL_ACQUIRE_TIMEOUT=

# Seconds of inactivity after which an idle connection is replaced. -1 disables
# Default: 300.0
DB_POOL_IDLE_TIMEOUT=

# Seconds before a running query is interrupted (QueryTimeoutError). -1 disables
# Default: 10.0
DB_QUERY_TIMEOUT=

# Bypass startup migration check — emergency use only
# Values: 1, true, yes
SKIP_MIGRATION_CHECK=


# =============================================================================
# Dashboard Authentication
# =============================================================================

# Dashboard login password — REQUIRED to enable password-based login
REX_DASHBOARD_PASSWORD=

# Secret key used to sign dashboard session tokens
# REQUIRED in production — a random value is generated at startup when absent,
# which invalidates sessions on every restart
REX_DASHBOARD_SECRET=

# Session expiry in seconds
# Default: 28800  (8 hours)
REX_DASHBOARD_SESSION_EXPIRY=

# Allow unauthenticated access from localhost (1=yes, 0=no)
# Default: 1
REX_DASHBOARD_ALLOW_LOCAL=1

# Maximum failed login attempts before lockout
# Default: 5
REX_LOGIN_MAX_ATTEMPTS=

# Lockout duration in seconds after too many failed attempts
# Default: 300
REX_LOGIN_LOCKOUT_SECONDS=


# =============================================================================
# Agent Server (rex-agent)
# =============================================================================

# Host address the agent server binds to
# Default: 127.0.0.1
REX_AGENT_HOST=

# Name of the environment variable from which the agent auth token is read
# Default: REX_AGENT_API_KEY
REX_AGENT_TOKEN_ENV=

# Comma-separated allowlist of agent IDs permitted to connect
# Default: *  (all agents allowed)
REX_AGENT_ALLOWLIST=


# =============================================================================
# Plugin System
# =============================================================================

# Maximum seconds a plugin may run before being killed
# Default: 30
REX_PLUGIN_TIMEOUT=

# Maximum bytes of output a plugin may produce per invocation
# Default: 1048576  (1 MiB)
REX_PLUGIN_OUTPUT_LIMIT=

# Max plugin invocations per minute per plugin
# Default: 10
REX_PLUGIN_RATE_LIMIT=


# =============================================================================
# Logging
# =============================================================================

# Root log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Per-module log-level override — replace <module> with the logger name,
# e.g. LOG_LEVEL_rex.llm_client=DEBUG
# LOG_LEVEL_<module>=<level>

# Enable JSON structured logging (1/true=on, 0/false=off)
# Default: on in production, off when running under pytest
REX_JSON_LOGS=

# Log full client IP addresses instead of anonymizing them (1=yes, 0=no)
# Default: 0  (last octet of IPv4 / last 64 bits of IPv6 are zeroed)
REX_LOG_FULL_IP=0


# =============================================================================
# Windows Service (rex-service)
# =============================================================================

# Comma-separated list of Rex sub-services to start under the Windows service
# Default: speak,proxy
REX_SERVICES=

# Port used by the Windows service manager
# Default: 5100
REX_SERVICE_PORT=


# =============================================================================
# Runtime / Miscellaneous
# =============================================================================

# Active user profile key used to select voice identity and memory
# Default: local
REX_ACTIVE_USER=local

# Graceful shutdown drain timeout in seconds
# Default: 5
REX_SHUTDOWN_TIMEOUT=
